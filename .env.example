# ==============================================
# DEPLOY AKIŞI: local → staging (Railway) → production (Railway)
#
# [ORTAMA GÖRE DEĞİŞEN] — her ortamda farklı değer
# [SHARED]              — tüm ortamlarda aynı kalabilir
# ==============================================


# ==============================================
# SUPABASE [SHARED]
# Tek Supabase projesi: staging, production ve local aynı DB'yi kullanır
# (prod için ayrı proje ayrılmadı). Migration'lar bu tek projeye uygulanır.
# Project Settings > API
# ==============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Not: Client doğrudan Supabase'e bağlanmaz (tüm erişim backend API + cookie-auth
# üzerinden). Bu yüzden VITE_SUPABASE_* değişkenleri YOK — eklemeye gerek yok.


# ==============================================
# URL'LER [ORTAMA GÖRE DEĞİŞEN]
# Local          → http://localhost:3001
# Staging        → https://staging.up.railway.app
# Production     → https://prod.up.railway.app
#
# Not: Railway'de server client'ı da servis ettiğinden
# VITE_API_URL boş bırakılabilir (relative path çalışır).
# ==============================================
VITE_API_URL=http://localhost:3001/api
# API_BASE_URL mail open/click takibinin pixel ve redirect linklerine gömülür;
# prod/staging'de public Railway URL'i olmalı. Set değilse takip sessizce devre dışı
# kalır (mail yine gönderilir).
API_BASE_URL=http://localhost:3001
CLIENT_URL=http://localhost:5173


# ==============================================
# SUNUCU [ORTAMA GÖRE DEĞİŞEN]
# NODE_ENV: local=development, Railway=production
# ==============================================
NODE_ENV=development
API_PORT=3001


# ==============================================
# PLUSVIBE [ORTAMA GÖRE DEĞİŞEN]
# Staging için ayrı PlusVibe workspace açılması önerilir.
# En azından PLUSVIBE_WEBHOOK_SECRET ortama göre farklı olsun.
# ==============================================
PLUSVIBE_WEBHOOK_SECRET=       # openssl rand -hex 16
PLUSVIBE_API_KEY=
PLUSVIBE_WORKSPACE_ID=


# ==============================================
# ENCRYPTION [ORTAMA GÖRE DEĞİŞEN]
# Tenant'ların SMTP/IMAP şifreleri DB'de AES-256-GCM ile şifrelenir.
# Her ortam için ayrı key üret: openssl rand -hex 32
# DİKKAT: Key kaybolursa tüm SMTP şifreleri çözülemez hale gelir.
#
# Key set edilmezse şifreleme fail-closed olur (kayıt başarısız olur).
# Sadece lokalde, gerçek veri olmadan çalışmak için güvensiz sıfır-key'e
# izin vermek istersen ALLOW_INSECURE_ENCRYPTION_KEY=true ver. Deploy'da ASLA.
# ==============================================
ENCRYPTION_KEY=
# ALLOW_INSECURE_ENCRYPTION_KEY=true


# ==============================================
# TG-LinkedIn [ORTAMA GÖRE DEĞİŞEN]
# Ekip üyelerinin LinkedIn session cookie'leri (li_at + JSESSIONID) DB'de
# AES-256-GCM ile şifrelenir. ENCRYPTION_KEY'den AYRI bir key domain'i —
# LinkedIn key rotasyonu SMTP/IMAP secret'larına dokunmasın diye.
# Her ortam için ayrı key üret: openssl rand -hex 32
# DİKKAT: Key kaybolursa tüm LinkedIn cookie'leri çözülemez (fail-closed).
# ==============================================
LINKEDIN_COOKIE_ENC_KEY=

# Sticky residential/5G proxy base credential. Hesap başına sabit exit IP,
# proxy_session_id'nin username'e enjekte edilmesiyle sağlanır (ROTATING değil).
# SADECE secret env'de tut — DB/imaj/client'a asla girmez.
# Form: http://USER:PASS@host:port
ROTATING_5G_PROXY=

# Uzantının cookie yakalama için deep-link'lediği origin (yoksa CLIENT_URL'e düşer;
# ikisi de yoksa link-token 500 verir — kırık göreli URL üretilmez).
LINKEDIN_APP_ORIGIN=


# ==============================================
# NANGO [SHARED]
# Drip kampanyaları kullanıcının kendi Gmail/Outlook hesabından gider.
# Nango Cloud: app.nango.dev → Environment Settings → Backend Secret Key
# Frontend SDK artık short-lived session token kullanıyor (public key
# Mart 2025'te deprecate edildi); session token backend'de üretiliyor,
# frontend ekstra env gerektirmiyor.
# Free tier 10 connection (10 tenant). Provider integration ID'ler
# kodda hardcoded: "google-mail" ve "microsoft-outlook" — değiştirme.
#
# NANGO_CALLBACK_URL: Google OAuth doğrulaması, redirect URI'nin bizim domain'imizde
# olmasını ister (nango.dev doğrulanamaz). Server /oauth-callback endpoint'i, Google'ı
# buraya yönlendirip query paramlarını koruyarak Nango'ya 308 atar. Değişkeni SET ETME;
# default Nango Cloud callback'idir (sadece self-hosted Nango'da değiştir). Asıl yapılacak:
# Google Cloud + Nango Environment Settings'te callback'i https://core.tibexa.com/oauth-callback
# yap. Detaylı rehber: docs/google-oauth-verification.md
# ==============================================
NANGO_SECRET_KEY=
# NANGO_CALLBACK_URL=https://api.nango.dev/oauth/callback


# ==============================================
# RESEND [SHARED — sistem/transactional mailler]
# Drip kampanyalar Nango (kullanıcının kendi mailbox'ı) üzerinden gider.
# Resend SADECE system mailler için: günlük aktivite özeti (info@tibexa.com'dan),
# ileride davet/password reset/bildirim vb.
#
# Kurulum:
#   1) resend.com → API Keys → yeni anahtar oluştur → RESEND_API_KEY'e koy
#   2) Domains → tibexa.com ekle → DNS panelinde SPF/DKIM/DMARC kayıtlarını gir
#   3) Domain "verified" görününce RESEND_FROM_EMAIL=info@tibexa.com çalışır
#
# Boş bırakılırsa system mail gönderimi otomatik atlanır (hata vermez).
# ==============================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=info@tibexa.com
RESEND_FROM_NAME=Tibexa Global


# ==============================================
# CAMPAIGN TRACKING [ORTAMA GÖRE DEĞİŞEN]
# TRACKING_SECRET her ortamda farklı olsun (güvenlik).
# ==============================================
TRACKING_SECRET=               # openssl rand -hex 32


# ==============================================
# POSTHOG [SHARED]
# Tüm ortamlarda aynı proje kullanılabilir.
# Staging eventlarını filtrele: NODE_ENV property'si üzerinden.
# Host genellikle https://eu.i.posthog.com
# ==============================================
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# ==============================================
# Cold Call (Twilio) — telephony provider
# ==============================================
# Master Twilio kimliği. İKİ modelden biri:
#   1) Account SID + Auth Token (en sorunsuz — webhook imzası doğrulanabilir)
#        TWILIO_ACCOUNT_SID + TWILIO_AUTH_TOKEN
#   2) Account SID + API Key (SK...) — auth token okunamadığından webhook
#      doğrulaması URL-secret ile yapılır (kod otomatik seçer)
#        TWILIO_ACCOUNT_SID + TWILIO_SID (SK...) + TWILIO_CLIENT_SECRET
# TWILIO_API_KEY_SID / TWILIO_API_KEY_SECRET adları da kabul edilir.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SID=
TWILIO_CLIENT_SECRET=
# Twilio'nun webhook'ları (voice/status/recording) çağıracağı PUBLIC HTTPS kök URL'i.
# Prod'da Railway servis URL'i; yerel testte cloudflared/ngrok tüneli.
COLDCALL_PUBLIC_URL=
# Kayıt transkripsiyonu için (opsiyonel — yoksa transcript 'failed' kalır)
DEEPGRAM_KEY=
