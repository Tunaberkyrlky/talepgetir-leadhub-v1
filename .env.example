# ==============================================
# DEPLOY AKIŞI: local → staging (Railway) → production (Railway)
#
# [ORTAMA GÖRE DEĞİŞEN] — her ortamda farklı değer
# [SHARED]              — tüm ortamlarda aynı kalabilir
# ==============================================


# ==============================================
# SUPABASE [ORTAMA GÖRE DEĞİŞEN]
# Staging ve production için ayrı Supabase projesi kullan.
# Local'de staging projesine bağlanmak yeterli.
# Project Settings > API
# ==============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key


# ==============================================
# URL'LER [ORTAMA GÖRE DEĞİŞEN]
# Local          → http://localhost:3001
# Staging        → https://staging.up.railway.app
# Production     → https://prod.up.railway.app
#
# Not: Railway'de server client'ı da servis ettiğinden
# VITE_API_URL boş bırakılabilir (relative path çalışır).
# ==============================================
VITE_API_URL=http://localhost:3001/api
API_BASE_URL=http://localhost:3001
CLIENT_URL=http://localhost:5173


# ==============================================
# SUNUCU [ORTAMA GÖRE DEĞİŞEN]
# NODE_ENV: local=development, Railway=production
# ==============================================
NODE_ENV=development
API_PORT=3001


# ==============================================
# PLUSVIBE [ORTAMA GÖRE DEĞİŞEN]
# Staging için ayrı PlusVibe workspace açılması önerilir.
# En azından PLUSVIBE_WEBHOOK_SECRET ortama göre farklı olsun.
# ==============================================
PLUSVIBE_WEBHOOK_SECRET=       # openssl rand -hex 16
PLUSVIBE_API_KEY=
PLUSVIBE_WORKSPACE_ID=


# ==============================================
# NANGO [SHARED]
# Drip kampanyaları kullanıcının kendi Gmail/Outlook hesabından gider.
# Nango Cloud: app.nango.dev → Environment Settings → Backend Secret Key
# Frontend SDK artık short-lived session token kullanıyor (public key
# Mart 2025'te deprecate edildi); session token backend'de üretiliyor,
# frontend ekstra env gerektirmiyor.
# Free tier 10 connection (10 tenant). Provider integration ID'ler
# kodda hardcoded: "google-mail" ve "microsoft-outlook" — değiştirme.
# ==============================================
NANGO_SECRET_KEY=


# ==============================================
# RESEND [SHARED — sistem/transactional mailler]
# Drip kampanyalar Nango (kullanıcının kendi mailbox'ı) üzerinden gider.
# Resend SADECE system mailler için: günlük aktivite özeti (info@tibexa.com'dan),
# ileride davet/password reset/bildirim vb.
#
# Kurulum:
#   1) resend.com → API Keys → yeni anahtar oluştur → RESEND_API_KEY'e koy
#   2) Domains → tibexa.com ekle → DNS panelinde SPF/DKIM/DMARC kayıtlarını gir
#   3) Domain "verified" görününce RESEND_FROM_EMAIL=info@tibexa.com çalışır
#
# Boş bırakılırsa system mail gönderimi otomatik atlanır (hata vermez).
# ==============================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=info@tibexa.com
RESEND_FROM_NAME=Tibexa Global


# ==============================================
# CAMPAIGN TRACKING [ORTAMA GÖRE DEĞİŞEN]
# TRACKING_SECRET her ortamda farklı olsun (güvenlik).
# ==============================================
TRACKING_SECRET=               # openssl rand -hex 32


# ==============================================
# POSTHOG [SHARED]
# Tüm ortamlarda aynı proje kullanılabilir.
# Staging eventlarını filtrele: NODE_ENV property'si üzerinden.
# Host genellikle https://eu.i.posthog.com
# ==============================================
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com
